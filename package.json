{
  "name": "logseq-lss-db-final-plugin",
  "version": "2.0.59",
  "title": "LSS DB Final Plugin",
  "description": "Modular LSS DB Final Plugin v2.0.59 — step-by-step setup, creation, audit/repair, and maintenance commands.",
  "main": "dist/index.html",
  "type": "module",
  "effect": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "rebuild": "rm -rf dist && npm run build",
    "package": "npm run rebuild && node scripts/package-release.mjs",
    "validate": "node scripts/validate.mjs && node scripts/validate-repair-logic.mjs"
  },
  "dependencies": {
    "@logseq/libs": "^0.3.3"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vite": "^8.0.16"
  },
  "logseq": {
    "id": "logseq-lss-db-final-plugin",
    "title": "LSS DB Final Plugin",
    "icon": "./assets/icon.svg"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "lodash-es": "4.18.1"
  }
}
